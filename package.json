{
  "name": "jclic",
  "title": "JClic.js",
  "description": "HTML5 player for JClic activities",
  "version": "2.3.0",
  "type": "module",
  "files": [
    "dist-node"
  ],
  "main": "./dist-node/jclic-node.umd.cjs",
  "module": "./dist-node/jclic-node.js",
  "exports": {
    ".": {
      "import": "./dist-node/jclic-node.js",
      "require": "./dist-node/jclic-node.umd.cjs"
    }
  },
  "jsdelivr": "dist/jclic.min.js",
  "homepage": "https://projectestac.github.io/jclic.js",
  "readmeFilename": "README.md",
  "author": {
    "name": "Catalan Educational Telematic Network (XTEC)",
    "email": "clic@xtec.cat",
    "url": "https://projectes.xtec.cat/clic/"
  },
  "contributors": [
    {
      "name": "Francesc Busquets",
      "email": "francesc@gmail.com",
      "url": "https://github.com/frncesc"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projectestac/jclic.js.git"
  },
  "keywords": [
    "jclic",
    "JClic",
    "java",
    "html5",
    "education",
    "game",
    "games",
    "puzzle",
    "puzzles",
    "activities"
  ],
  "bugs": {
    "url": "https://github.com/projectestac/jclic.js/issues"
  },
  "licenses": [
    {
      "type": "EUPL-1.2",
      "url": "https://spdx.org/licenses/EUPL-1.2.html"
    }
  ],
  "license": "EUPL-1.2",
  "dependencies": {
    "@francesc/basic-midi-player-js": "^3.0.2",
    "@xmldom/xmldom": "^0.9.10",
    "jquery": "^4.0.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "jszip-utils": "0.1.0"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "clean-jsdoc-theme": "^4.3.2",
    "eslint": "^10.4.1",
    "fs-extra": "^11.3.5",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "patch-package": "^8.0.1",
    "po2json": "^1.0.0-alpha",
    "vite": "^8.0.16",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-eslint": "^1.8.1"
  },
  "scripts": {
    "dev": "vite --config vite.browser-config.js",
    "build": "vite --config vite.browser-config.js build && cd dist && ln -s ../test . && cd ..",
    "build-node": "vite --config vite.node-config.js build",
    "preview": "vite --config vite.browser-config.js preview",
    "lint": "eslint src --ext .js,.css",
    "prebuild": "patch-package",
    "build-locales": "node build-locales.js",
    "build-doc": "rm -r doc && jsdoc -c jsdoc-config.json",
    "prestart": "patch-package"
  },
  "browserslist": "> 0.25%, not dead",
  "browser": {
    "jsdom": false,
    "@xmldom/xmldom": false
  }
}
